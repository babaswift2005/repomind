# Ollama configuration
OLLAMA_URL=http://localhost:11434

# Model for chat and code summaries
# Options: llama3.2, codellama, mistral, deepseek-coder, etc.
OLLAMA_MODEL=llama3.2

# Model for embeddings (semantic search)
# Must be an embedding model: nomic-embed-text, mxbai-embed-large, etc.
OLLAMA_EMBED_MODEL=nomic-embed-text

# Max number of files to analyze per repository (increase for thorough analysis)
MAX_ANALYZE_FILES=80
