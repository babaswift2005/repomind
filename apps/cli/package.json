{
  "name": "repomind-cli",
  "version": "1.0.0",
  "description": "CLI tool for RepoMind — AI that explains any GitHub repository",
  "bin": {
    "repomind": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup src/index.ts --format cjs --target node18 --outDir dist",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "inquirer": "^10.1.0",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/inquirer": "^9.0.7",
    "typescript": "^5",
    "tsx": "^4.15.0",
    "tsup": "^8.1.0"
  },
  "type": "module"
}
